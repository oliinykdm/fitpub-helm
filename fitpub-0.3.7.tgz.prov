annotations:
  artifacthub.io/category: skip-prediction
  artifacthub.io/changes: |
    - kind: fixed
      description: Omit mail settings from the default ConfigMap until FITPUB_MAIL_HOST is set; avoids localhost:587 with forced SMTP auth.
    - kind: added
      description: Optional config keys for Hikari pool, ActivityPub inbox tuning, FITPUB_MAIL_PROTOCOL, OSM tiles and weather toggles.
    - kind: fixed
      description: Block multi-replica and RollingUpdate deployments with ReadWriteOnce upload volumes (including existingClaim).
    - kind: added
      description: CI runtime test for networkpolicy-smoke-values.yaml with restricted egress.
    - kind: fixed
      description: Documentation fixes (kubectl exec, README secret placeholders, ingress forwarded headers, application logs).
  artifacthub.io/containsSecurityUpdates: "false"
