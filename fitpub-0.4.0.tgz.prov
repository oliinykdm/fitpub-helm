Hash: SHA512

annotations:
  artifacthub.io/category: skip-prediction
  artifacthub.io/changes: |
    - kind: added
      description: Enable readOnlyRootFilesystem by default with emptyDir mounts for /tmp and /app/logs; the chart is now restricted Pod Security Standard compliant out of the box.
    - kind: added
      description: CPU limit, PodDisruptionBudget and a preStop drain hook are now on by default for production reliability.
    - kind: added
      description: NetworkPolicy ingress now supports a from selector, and serviceMonitor supports basicAuth.
    - kind: changed
      description: Default the volume-permissions init container off (fsGroup handles ownership); enable it only for StorageClasses that ignore fsGroup.
    - kind: changed
      description: ServiceMonitor path back to /actuator/metrics; the app ships no Prometheus registry and gates actuator behind auth.
  artifacthub.io/containsSecurityUpdates: "false"
  artifacthub.io/images: |
    - name: fitpub
      image: codeberg.org/fitpub/fitpub:1.1.1
    - name: volume-permissions
      image: busybox:1.37
      whitelisted: true
  artifacthub.io/license: Apache-2.0
