annotations:
  artifacthub.io/category: skip-prediction
  artifacthub.io/changes: |
    - kind: fixed
      description: Corrected config keys that the app never read - app log level (LOGGING_LEVEL_NET_JAVAHIPPIE_FITPUB), JWT lifetime (FITPUB_SECURITY_JWT_EXPIRATION) and upload size (SPRING_SERVLET_MULTIPART_*).
    - kind: added
      description: FITPUB_FEDERATION_PROTOCOL and FITPUB_ALLOW_PRIVATE_IPS config knobs.
    - kind: added
      description: Reject a FITPUB_DOMAIN that contains a scheme or trailing slash, and a FITPUB_FEDERATION_PROTOCOL other than http/https.
    - kind: fixed
      description: NOTES.txt write-test command now uses persistence.mountPath instead of a hardcoded /app/uploads.
