annotations:
  artifacthub.io/category: skip-prediction
  artifacthub.io/changes: |
    - kind: changed
      description: Default probes use GET /login (HTTP 200) for reliable startup on FitPub 1.1.x where actuator health requires authentication.
    - kind: changed
      description: Default ServiceMonitor path is /actuator/metrics (prometheus endpoint is not in the app image).
    - kind: changed
      description: Fail render when networkPolicy blocks all egress without extraRules.
    - kind: removed
      description: Drop inert config.FITPUB_ACTIVITYPUB_ENABLED (not read by the application).
