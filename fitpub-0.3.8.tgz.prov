annotations:
  artifacthub.io/category: skip-prediction
  artifacthub.io/changes: |
    - kind: fixed
      description: Render boolean/number config and secret values (false, 0) instead of silently dropping them; empty strings and null are still omitted.
    - kind: fixed
      description: Correct the README restricted-egress NetworkPolicy example (ClusterIP DNS now allows TCP 53; SMTP 587 is a separate rule).
    - kind: fixed
      description: Production example and README now provision FITPUB_MAIL_USERNAME/FITPUB_MAIL_PASSWORD when FITPUB_MAIL_SMTP_AUTH is true.
    - kind: added
      description: Document that the volume-permissions init container is incompatible with the restricted Pod Security Standard and how to disable it.
  artifacthub.io/containsSecurityUpdates: "false"
  artifacthub.io/images: |
    - name: fitpub
      image: codeberg.org/fitpub/fitpub:1.1.1
    - name: volume-permissions
